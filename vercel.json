{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/frontend/home%20page/code/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/public/:path*"
    }
  ]
}
